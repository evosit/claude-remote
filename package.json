{
  "name": "@hoangvu12/claude-remote",
  "version": "1.2.0",
  "description": "Remote Control for Claude Code - monitor and interact with Claude Code sessions from your phone",
  "type": "module",
  "bin": {
    "claude-remote": "dist/cli.js",
    "remote-cmd": "dist/remote-cmd.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test:smoke": "claude-remote --version && claude-remote help",
    "debug": "DEBUG=claude-remote:* claude-remote $*"
  },
  "keywords": [
    "claude",
    "claude-code",
    "remote-control",
    "discord",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hoangvu12/claude-remote.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chokidar": "^4.0.3",
    "debug": "^4.4.3",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.5",
    "node-pty": "^1.0.0",
    "picocolors": "^1.1.1",
    "which": "^2.0.2"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^22.13.10",
    "@types/which": "^3.0.4",
    "typescript": "^5.8.2"
  }
}
